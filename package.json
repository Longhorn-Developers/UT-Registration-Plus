{
    "name": "ut-registration-plus",
    "displayName": "UT Registration Plus",
    "version": "2.4.1",
    "description": "UT Registration Plus is a Chrome extension that allows students to easily register for classes.",
    "private": true,
    "homepage": "https://github.com/Longhorn-Developers/UT-Registration-Plus",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsgo && vite build",
        "build:dev": "tsgo && NODE_ENV='development' vite build --mode development",
        "build:watch": "NODE_ENV='development' vite build --mode development -w",
        "zip": "pnpm build && pnpm gulp zipProdBuild",
        "zip:to-publish": "SENTRY_ENV='production' pnpm zip",
        "format": "biome format",
        "format:fix": "biome format --write",
        "lint": "biome lint",
        "lint:fix": "biome lint --write",
        "check": "biome check",
        "check:fix": "biome check --write",
        "check-types": "tsgo --noEmit",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "coverage": "vitest run --coverage",
        "preview": "vite preview",
        "generate-changelog": "bun run scripts/generateChangelog.ts",
        "preinstall": "npx only-allow pnpm",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "prepare": "husky"
    },
    "dependencies": {
        "@date-fns/tz": "^1.4.1",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/modifiers": "^9.0.0",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@headlessui/react": "^2.2.9",
        "@octokit/rest": "^22.0.1",
        "@phosphor-icons/react": "^2.1.10",
        "@sentry/react": "^10.42.0",
        "@tanstack/react-query": "^5.90.21",
        "@tsparticles/engine": "^3.9.1",
        "@tsparticles/react": "^3.0.0",
        "@tsparticles/slim": "^3.9.1",
        "@typescript/native-preview": "7.0.0-dev.20260312.1",
        "@unocss/vite": "^66.6.6",
        "@vitejs/plugin-react": "^5.1.4",
        "clsx": "^2.1.1",
        "conventional-changelog": "^7.2.0",
        "date-fns": "^4.1.0",
        "highcharts": "^12.5.0",
        "highcharts-react-official": "^3.2.3",
        "html-to-image": "^1.11.13",
        "husky": "^9.1.7",
        "kc-dabr-wasm": "^0.1.2",
        "nanoid": "^5.1.6",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-loading-skeleton": "^3.5.0",
        "react-markdown": "^9.1.0",
        "react-syntax-highlighter": "^15.6.6",
        "remark-gfm": "^4.0.1",
        "sass": "^1.97.3",
        "simple-git": "^3.32.3",
        "sql.js": "1.14.1"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.9",
        "@chromatic-com/storybook": "^5.0.1",
        "@commitlint/cli": "^20.4.3",
        "@commitlint/config-conventional": "^20.4.3",
        "@commitlint/types": "^20.4.3",
        "@crxjs/vite-plugin": "2.3.0",
        "@iconify-json/bi": "^1.2.7",
        "@iconify-json/ic": "^1.2.4",
        "@iconify-json/iconoir": "^1.2.10",
        "@iconify-json/material-symbols": "^1.2.60",
        "@iconify-json/ph": "^1.2.2",
        "@iconify-json/ri": "^1.2.10",
        "@iconify-json/streamline": "^1.2.5",
        "@semantic-release/exec": "^7.1.0",
        "@sentry/types": "^10.42.0",
        "@storybook/addon-designs": "^11.1.2",
        "@storybook/react": "^10.2.16",
        "@storybook/react-vite": "^10.2.16",
        "@svgr/core": "^8.1.0",
        "@svgr/plugin-jsx": "^8.1.0",
        "@types/chrome": "^0.1.37",
        "@types/conventional-changelog": "^6.0.1",
        "@types/gulp": "^4.0.18",
        "@types/gulp-zip": "^4.0.4",
        "@types/node": "^22.19.15",
        "@types/prompts": "^2.4.9",
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.3.7",
        "@types/react-syntax-highlighter": "^15.5.13",
        "@types/semver": "^7.7.1",
        "@types/sql.js": "^1.4.9",
        "@unocss/postcss": "^66.6.6",
        "@unocss/preset-uno": "^66.6.6",
        "@unocss/preset-web-fonts": "^66.6.6",
        "@unocss/reset": "^66.6.6",
        "@unocss/transformer-directives": "^66.6.6",
        "@unocss/transformer-variant-group": "^66.6.6",
        "@vitejs/plugin-react-swc": "^4.2.3",
        "@vitest/coverage-v8": "^4.0.18",
        "@vitest/ui": "^4.0.18",
        "chalk": "^5.6.2",
        "chromatic": "^15.2.0",
        "cssnano": "^7.1.3",
        "cssnano-preset-advanced": "^7.0.11",
        "dotenv": "^17.3.1",
        "es-module-lexer": "^1.7.0",
        "gulp": "^5.0.1",
        "gulp-execa": "^8.0.1",
        "gulp-zip": "^6.1.0",
        "jsdom": "^28.1.0",
        "path": "^0.12.7",
        "postcss": "^8.5.8",
        "react-dev-utils": "^12.0.1",
        "semantic-release": "^25.0.3",
        "storybook": "^10.2.16",
        "typescript": "^5.9.3",
        "unocss": "^66.6.6",
        "unocss-preset-primitives": "0.0.2-beta.2",
        "unplugin-icons": "^23.0.1",
        "vite": "^7.3.1",
        "vite-plugin-inspect": "^11.3.3",
        "vitest": "^4.0.18"
    },
    "engineStrict": true,
    "engines": {
        "node": "^24.14",
        "pnpm": "^10"
    },
    "pnpm": {
        "overrides": {
            "es-module-lexer": "^1.7.0"
        },
        "onlyBuiltDependencies": [
            "@parcel/watcher",
            "@swc/core",
            "@tsparticles/engine",
            "esbuild"
        ],
        "blockExoticSubdeps": true
    },
    "packageManager": "pnpm@10.33.0"
}
